/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "paths": {
      "api": ["./projects/api/src/public-api.ts"],
      "contracts": ["./projects/contracts/src/public-api.ts"],
      "realtime": ["./projects/realtime/src/public-api.ts"],
      "ui": ["./projects/ui/src/public-api.ts"]
    },
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve"
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true
  },
  "files": [],
  "references": [
    {
      "path": "./projects/tv/tsconfig.app.json"
    },
    {
      "path": "./projects/tv/tsconfig.spec.json"
    },
    {
      "path": "./projects/phone/tsconfig.app.json"
    },
    {
      "path": "./projects/phone/tsconfig.spec.json"
    },
    {
      "path": "./projects/contracts/tsconfig.lib.json"
    },
    {
      "path": "./projects/contracts/tsconfig.spec.json"
    },
    {
      "path": "./projects/realtime/tsconfig.lib.json"
    },
    {
      "path": "./projects/realtime/tsconfig.spec.json"
    },
    {
      "path": "./projects/api/tsconfig.lib.json"
    },
    {
      "path": "./projects/api/tsconfig.spec.json"
    },
    {
      "path": "./projects/ui/tsconfig.lib.json"
    },
    {
      "path": "./projects/ui/tsconfig.spec.json"
    }
  ]
}
